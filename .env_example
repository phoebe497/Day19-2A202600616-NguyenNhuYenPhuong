# Copy this file to .env, then fill in your real key and base URL.
# The script uses an OpenAI-compatible Chat Completions API.

OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Use any chat model supported by your provider/base_url.
OPENAI_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0

# Cost controls for LLM triple extraction.
# Increase these values for better corpus coverage; decrease them to save tokens.
GRAPHRAG_CHUNK_CHARS=6000
GRAPHRAG_MAX_CHUNKS_PER_DOC=3

